{
	"extends": "tsconfig/node18.json",
	"compilerOptions": {
		"module": "commonjs",
		"target": "es6",
		"outDir": "dist",
		"baseUrl": ".",
		"typeRoots" : ["./node_modules/@types", "./src/infrastructure/@types"],
		"paths": {
			"@common/*": [
				"./src/common/*"
			],
			"@infrastructure/*": [
				"./src/infrastructure/*"
			],
			"@feature/*": [
				"./src/feature/*"
			],
			"@config/*": [
				"./src/config/*"
			]
		}
	},
	"include": [
		"**/*.ts"
	],
	"exclude": [
		"node_modules"
	]
}
