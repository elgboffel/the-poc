{
	"include": [
		"**/*.ts"
	],
	"exclude": [
		"node_modules"
	],
	"compilerOptions": {
		"baseUrl": ".",
		"rootDir": ".",
		"skipLibCheck": true,
		"sourceMap": true,
		"outDir": "dist",
		"strict": true,
		"lib": [
			"esnext",
			"dom"
		],
		"esModuleInterop": true,
		"paths": {
			"@common/*": [
				"./src/common/*"
			],
			"@infrastructure/*": [
				"./src/infrastructure/*"
			],
			"@feature/*": [
				"./src/feature/*"
			],
			"@config/*": [
				"./src/config/*"
			]
		}
	}
}
